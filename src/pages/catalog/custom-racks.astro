---
import Header from "../../components/Header.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import FloatingContact from "../../components/FloatingContact.astro";

const page = {
  title: "Custom Shelving & Racks Fabrication in Sri Lanka",

  seoTitle:
    "Custom Shelving & Racks Fabrication in Sri Lanka | Vahako",

  metaDescription:
    "Vahako designs, fabricates and installs custom shelving and rack systems in Sri Lanka for warehouses, showrooms, shops, hotels, schools, libraries, laboratories, offices and homes.",

  canonicalUrl:
    "https://vahako.com/catalog/custom-racks/",

  heroImage:
    "/images/catalog/custom-racks/racks-display-shop-sri-lanka.webp",

  heroAlt:
    "Custom shelving and rack fabrication for shops, warehouses and commercial spaces in Sri Lanka",

  intro:
    "Vahako designs, fabricates and installs custom shelving and rack systems for businesses, institutions and homes throughout Sri Lanka. From showroom display racks and warehouse storage systems to library shelves, laboratory racks, bathroom racks and decorative display units, every project is made specifically for the customer. Our team can visit your location, understand what you need to store or display, measure the available space and manufacture a durable, practical and visually impressive solution using stainless steel, mild steel, iron, wood, glass or a combination of materials.",

  rackCategories: [
    {
      eyebrow: "For Warehouses",

      title: "Warehouse Storage Racks",

      image:
        "/images/catalog/custom-racks/warehouse-rack-price-in-sri-lanka.webp",

      alt:
        "Custom warehouse storage racks fabricated in Sri Lanka by Vahako",

      description:
        "Strong custom warehouse racks designed around your available floor space, product sizes, storage capacity and daily operations. Suitable for warehouses, stockrooms, factories, workshops and distribution centres."
    },

    {
      eyebrow: "For Showrooms & Shops",

      title: "Showroom & Display Racks",

      image:
        "/images/catalog/custom-racks/showroom-racks-in-sri-lanka.webp",

      alt:
        "Custom showroom and shop display racks manufactured in Sri Lanka",

      description:
        "Professional showroom and shop display racks made to present products clearly and attractively. We fabricate wall-mounted racks, floor-standing displays, luxury shelving and customised retail display units."
    },

    {
      eyebrow: "For Schools, Libraries & Laboratories",

      title: "Library & Laboratory Racks",

      image:
        "/images/catalog/custom-racks/library-book-rack-price-in-sri-lanka.webp",

      alt:
        "Custom library book racks and laboratory shelving fabricated in Sri Lanka",

      description:
        "Purpose-built shelving for schools, colleges, libraries, study rooms and laboratories. Each rack is designed according to the books, files, equipment, materials or instruments that need to be safely organised."
    },

    {
      eyebrow: "For Homes, Hotels & Bathrooms",

      title: "Bathroom Racks",

      image:
        "/images/catalog/custom-racks/bathroom-rack-price-in-sri-lanka.webp",

      alt:
        "Custom bathroom racks for homes and hotels in Sri Lanka",

      description:
        "Custom bathroom racks for towels, toiletries, personal items and decorative accessories. We fabricate practical wall-mounted and floor-standing designs for homes, hotels, apartments and commercial washrooms."
    },

    {
      eyebrow: "For Decorative Display",

      title: "Ornamental & Decorative Racks",

      image:
        "/images/catalog/custom-racks/ornament-rack-price-in-sri-lanka.webp",

      alt:
        "Custom ornamental and decorative display racks in Sri Lanka",

      description:
        "Elegant display racks created for ornaments, artwork, trophies, collectibles, plants and decorative objects. Ideal for homes, hotels, reception areas, restaurants, offices and luxury commercial interiors."
    }
  ]
};
---

<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>{page.seoTitle}</title>

    <meta
      name="description"
      content={page.metaDescription}
    />

    <link
      rel="canonical"
      href={page.canonicalUrl}
    />
  </head>

  <body>
    <Header />

    <main>
      <!-- Hero Section -->

      <section class="catalog-hero">
        <div class="catalog-hero-inner">
          <div class="catalog-hero-image">
            <img
              src={page.heroImage}
              alt={page.heroAlt}
              width="800"
              height="800"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <div class="catalog-hero-content">
            <p class="hero-eyebrow">
              Custom Designed • Fabricated • Installed
            </p>

            <h1>{page.title}</h1>

            <p class="hero-description">
              {page.intro}
            </p>

            <ul class="hero-highlights" aria-label="Rack fabrication services">
              <li>Showroom Display Racks</li>
              <li>Warehouse Storage Systems</li>
              <li>Library & Laboratory Shelving</li>
              <li>Bathroom & Decorative Racks</li>
              <li>Steel, Wood & Glass Designs</li>
              <li>Site Visit & Installation</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Rack Categories -->

      <section
        class="rack-categories-section"
        aria-labelledby="rack-categories-title"
      >
        <div class="rack-categories-inner">
          <div class="rack-categories-heading">
            <p class="section-eyebrow">
              Our Custom Rack Solutions
            </p>

            <h2 id="rack-categories-title">
              Explore Our Shelving & Rack Categories
            </h2>

            <p class="section-intro">
              Every rack is custom made according to the client's space,
              products, storage requirements, preferred materials and design
              expectations. We do not limit customers to standard sizes or
              ready-made designs.
            </p>
          </div>

          <div class="rack-categories-grid">
            {
              page.rackCategories.map((category) => (
                <article class="rack-card">
                  <div class="rack-card-image">
                    <img
                      src={category.image}
                      alt={category.alt}
                      width="600"
                      height="600"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>

                  <div class="rack-card-content">
                    <span class="rack-card-eyebrow">
                      {category.eyebrow}
                    </span>

                    <h3>{category.title}</h3>

                    <p>{category.description}</p>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="custom-made-message">
            <div class="custom-made-icon" aria-hidden="true">
              ✓
            </div>

            <div>
              <p class="custom-made-eyebrow">
                Made Specifically for You
              </p>

              <h2>
                We Craft What the Client Wants
              </h2>

              <p>
                Tell us what you need to store or display, where the rack will
                be installed and the style you prefer. Our team can visit your
                location, take measurements, recommend materials and fabricate
                a completely custom solution using stainless steel, mild
                steel, iron, wood, glass or a combination of materials.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact Section -->

      <ContactCTA
        eyebrow="Discuss your shelving project"
        title="Contact Vahako"
        description="Talk to our fabrication team about custom shelving and rack systems for warehouses, showrooms, shops, hotels, schools, libraries, laboratories, offices and homes in Sri Lanka."
        whatsappMessage="Hello Vahako, I am interested in custom shelving and rack fabrication. Please provide more information."
        quotePage="Custom Shelving & Racks"
      />

      <FloatingContact
        pageName="Custom Shelving & Racks"
        whatsappMessage="Hello Vahako, I am interested in custom shelving and rack fabrication. Please provide more information."
        quotePage="Custom Shelving & Racks"
      />
    </main>
  </body>
</html>

<style>
  :global(html) {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    scroll-behavior: smooth;
  }

  :global(body) {
    width: 100%;
    max-width: 100%;
    margin: 0;
    overflow-x: hidden;

    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      "Helvetica Neue",
      Arial,
      sans-serif;

    background: #ffffff;
    color: #111827;
    text-rendering: optimizeLegibility;
  }

  main,
  main *,
  main *::before,
  main *::after {
    box-sizing: border-box;
  }

  main {
    width: 100%;
  }

  main img {
    max-width: 100%;
  }

  /* Hero Section */

  .catalog-hero {
    padding: 120px 20px 80px;
    background: #ffffff;
  }

  .catalog-hero-inner {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 60px;
    align-items: center;

    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .catalog-hero-image,
  .catalog-hero-content {
    min-width: 0;
  }

  .catalog-hero-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;

    border-radius: 20px;
    background: #f3f4f6;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.1);
  }

  .catalog-hero-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-eyebrow {
    margin: 0 0 14px;

    color: #e30613;
    font-size: 13px;
    line-height: 1.4;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .catalog-hero-content h1 {
    margin: 0 0 24px;

    color: #e30613;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -0.035em;
  }

  .hero-description {
    max-width: 620px;
    margin: 0 0 30px;

    color: #334155;
    font-size: 18px;
    line-height: 1.72;
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 26px;

    margin: 0;
    padding: 0;

    list-style: none;
  }

  .hero-highlights li {
    position: relative;
    padding-left: 26px;

    color: #111827;
    font-size: 15px;
    line-height: 1.45;
    font-weight: 800;
  }

  .hero-highlights li::before {
    content: "✓";

    position: absolute;
    top: 0;
    left: 0;

    color: #e30613;
    font-weight: 900;
  }

  /* Categories Section */

  .rack-categories-section {
    padding: 80px 20px 90px;

    border-top: 1px solid #e5e7eb;
    background: #ffffff;

    content-visibility: auto;
    contain-intrinsic-size: 1400px;
  }

  .rack-categories-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .rack-categories-heading {
    max-width: 820px;
    margin: 0 auto 48px;
    text-align: center;
  }

  .section-eyebrow {
    margin: 0 0 10px;

    color: #e30613;
    font-size: 13px;
    line-height: 1.4;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .rack-categories-heading h2 {
    margin: 0 0 18px;

    color: #e30613;
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.035em;
  }

  .section-intro {
    margin: 0;

    color: #475569;
    font-size: 17px;
    line-height: 1.68;
  }

  .rack-categories-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 30px 26px;
  }

  .rack-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;

    border: 1px solid #e5e7eb;
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .rack-card-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f3f4f6;
  }

  .rack-card-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;

    transition: transform 0.35s ease;
  }

  .rack-card-content {
    flex: 1;
    padding: 23px;
  }

  .rack-card-eyebrow {
    display: block;
    margin-bottom: 8px;

    color: #64748b;
    font-size: 12px;
    line-height: 1.4;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .rack-card-content h3 {
    margin: 0 0 12px;

    color: #e30613;
    font-size: 23px;
    line-height: 1.24;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .rack-card-content p {
    margin: 0;

    color: #334155;
    font-size: 15px;
    line-height: 1.65;
  }

  /* Custom-made Message */

  .custom-made-message {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 22px;
    align-items: flex-start;

    margin-top: 48px;
    padding: 34px;

    border: 1px solid rgba(227, 6, 19, 0.16);
    border-radius: 20px;

    background:
      linear-gradient(
        135deg,
        rgba(227, 6, 19, 0.055),
        rgba(255, 214, 0, 0.08)
      );

    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.07);
  }

  .custom-made-icon {
    display: grid;
    place-items: center;

    width: 58px;
    height: 58px;

    border-radius: 16px;
    background: #e30613;

    color: #ffffff;
    font-size: 28px;
    font-weight: 900;
  }

  .custom-made-eyebrow {
    margin: 0 0 7px;

    color: #e30613;
    font-size: 12px;
    line-height: 1.4;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .custom-made-message h2 {
    margin: 0 0 12px;

    color: #111827;
    font-size: clamp(27px, 3vw, 38px);
    line-height: 1.15;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .custom-made-message p:last-child {
    max-width: 930px;
    margin: 0;

    color: #334155;
    font-size: 16px;
    line-height: 1.7;
  }

  @media (hover: hover) and (pointer: fine) {
    .rack-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 18px 38px rgba(15, 23, 42, 0.12);
    }

    .rack-card:hover .rack-card-image img {
      transform: scale(1.04);
    }
  }

  /* Tablet */

  @media (max-width: 900px) {
    .catalog-hero {
      padding-top: 145px;
      padding-bottom: 60px;
    }

    .catalog-hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .catalog-hero-content {
      text-align: center;
    }

    .hero-description {
      margin-right: auto;
      margin-left: auto;
    }

    .hero-highlights {
      max-width: 650px;
      margin: 0 auto;
      text-align: left;
    }

    .rack-categories-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Mobile */

  @media (max-width: 600px) {
    .catalog-hero {
      padding: 130px 16px 54px;
    }

    .catalog-hero-inner {
      gap: 29px;
    }

    .catalog-hero-image {
      border-radius: 15px;
    }

    .catalog-hero-content h1 {
      margin-bottom: 19px;
      font-size: clamp(34px, 10vw, 47px);
    }

    .hero-description {
      margin-bottom: 25px;
      font-size: 16px;
      line-height: 1.65;
    }

    .hero-highlights {
      grid-template-columns: 1fr;
      gap: 12px;
      max-width: 360px;
    }

    .rack-categories-section {
      padding: 60px 16px 68px;
      contain-intrinsic-size: 2500px;
    }

    .rack-categories-heading {
      margin-bottom: 35px;
    }

    .rack-categories-heading h2 {
      font-size: clamp(31px, 9vw, 42px);
    }

    .section-intro {
      font-size: 16px;
    }

    .rack-categories-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .rack-card-content {
      padding: 21px;
      text-align: center;
    }

    .rack-card-content h3 {
      font-size: 22px;
    }

    .custom-made-message {
      grid-template-columns: 1fr;
      gap: 18px;

      margin-top: 36px;
      padding: 25px 21px;

      text-align: center;
    }

    .custom-made-icon {
      margin: 0 auto;
    }
  }

  /* Reduced Motion */

  @media (prefers-reduced-motion: reduce) {
    :global(html) {
      scroll-behavior: auto;
    }

    .rack-card,
    .rack-card-image img {
      transition: none;
    }

    .rack-card:hover {
      transform: none;
    }

    .rack-card:hover .rack-card-image img {
      transform: none;
    }
  }
</style>