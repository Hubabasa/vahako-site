---
import Header from "../components/Header.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Get a Quote | Vahako</title>

    <meta
      name="description"
      content="Request a quotation from Vahako for fabrication, conveyor systems and industrial services in Sri Lanka."
    />

    <meta name="robots" content="noindex,follow" />
  </head>

  <body>
    <Header />

    <main class="quote-page">
      <section class="quote-section">
        <div class="quote-container">
          <div class="quote-heading">
            <p class="eyebrow">Request a quotation</p>

            <h1>Get a Quote</h1>

            <p>
              Complete the form below and our team will contact you shortly.
            </p>
          </div>

          <form id="quote-form" class="quote-form" novalidate>
            <div class="form-field">
              <label for="source-page">Page you contacted us from</label>

              <input
                id="source-page"
                name="sourcePage"
                type="text"
                readonly
                required
              />
            </div>

            <div class="form-field">
              <label for="company-name">
                Company name
                <span>Optional</span>
              </label>

              <input
                id="company-name"
                name="companyName"
                type="text"
                autocomplete="organization"
                maxlength="120"
              />
            </div>

            <div class="form-field">
              <label for="contact-person">
                Contact person
                <span>Optional</span>
              </label>

              <input
                id="contact-person"
                name="contactPerson"
                type="text"
                autocomplete="name"
                maxlength="100"
              />
            </div>

            <div class="form-field">
              <label for="contact-number">
                Contact number
                <strong>*</strong>
              </label>

              <input
                id="contact-number"
                name="contactNumber"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                maxlength="20"
                required
                aria-describedby="contact-help"
              />

              <small id="contact-help">
                This field is required.
              </small>
            </div>

            <div class="form-field">
              <label for="alternative-number">
                Alternative contact number
                <span>Optional</span>
              </label>

              <input
                id="alternative-number"
                name="alternativeContactNumber"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                maxlength="20"
              />
            </div>

            <div class="form-field">
              <label for="email">
                Email address
                <span>Optional</span>
              </label>

              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                maxlength="160"
              />
            </div>

            <button class="submit-button" type="submit">
              Submit Quote Request
            </button>

            <div
              id="success-message"
              class="form-message success-message"
              role="status"
              hidden
            >
              Successful. You will be contacted soon.
            </div>

            <div
              id="failure-message"
              class="form-message failure-message"
              role="alert"
              hidden
            >
              Submission failed. Please contact us directly.
            </div>
          </form>
        </div>
      </section>
    </main>

    <script>
  const params = new URLSearchParams(window.location.search);

  const sourcePageInput = document.getElementById("source-page");
  const form = document.getElementById("quote-form");
  const submitButton = form.querySelector(".submit-button");
  const successMessage = document.getElementById("success-message");
  const failureMessage = document.getElementById("failure-message");

  const pageFromUrl = params.get("page")?.trim();

  sourcePageInput.value =
    pageFromUrl || document.referrer || "Vahako website";

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    successMessage.hidden = true;
    failureMessage.hidden = true;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitButton.disabled = true;
    submitButton.textContent = "Submitting...";

    const formData = new FormData(form);

    const payload = {
      sourcePage: String(formData.get("sourcePage") || "").trim(),
      companyName: String(formData.get("companyName") || "").trim(),
      contactPerson: String(formData.get("contactPerson") || "").trim(),
      contactNumber: String(formData.get("contactNumber") || "").trim(),
      alternativeContactNumber: String(
        formData.get("alternativeContactNumber") || ""
      ).trim(),
      email: String(formData.get("email") || "").trim()
    };

    try {
      const response = await fetch("/api/quote", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.message || "Submission failed.");
      }

      successMessage.textContent =
        result.message || "Successful. You will be contacted soon.";

      successMessage.hidden = false;

      form.reset();

      sourcePageInput.value =
        pageFromUrl || document.referrer || "Vahako website";
    } catch (error) {
      failureMessage.innerHTML =
        'Submission failed. Please contact us on WhatsApp at <a href="https://wa.me/94707797770?text=I%20am%20interested%20in%20Vahako%20services" target="_blank" rel="noopener noreferrer">070 779 7770</a>.';

      failureMessage.hidden = false;
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Submit Quote Request";
    }
  });
</script>

  </body>
</html>

<style>
  .quote-page,
.quote-page * {
  box-sizing: border-box;
}

  body {
    margin: 0;
    font-family: Helvetica, Arial, system-ui, sans-serif;
    background: #ffffff;
    color: #111827;
  }

  .quote-page {
    min-height: 100vh;
    padding-top: 105px;
    background: #ffffff;
  }

  .quote-section {
    padding: 64px 20px 80px;
  }

  .quote-container {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
  }

  .quote-heading {
    margin-bottom: 36px;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: #e30613;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .quote-heading h1 {
    margin: 0 0 14px;
    color: #e30613;
    font-size: clamp(38px, 6vw, 62px);
    line-height: 1;
    font-weight: 900;
    letter-spacing: -1px;
  }

  .quote-heading > p:last-child {
    margin: 0;
    color: #475569;
    font-size: 17px;
    line-height: 1.6;
  }

  .quote-form {
    display: grid;
    gap: 22px;
    padding: 32px;
    border: 1px solid #e5e7eb;
    border-top: 3px solid #ffd600;
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.07);
  }

  .form-field {
    display: grid;
    gap: 8px;
  }

  .form-field label {
    color: #111827;
    font-size: 15px;
    font-weight: 800;
  }

  .form-field label span {
    color: #64748b;
    font-size: 12px;
    font-weight: 500;
  }

  .form-field label strong {
    color: #e30613;
  }

  .form-field input {
    width: 100%;
    min-height: 48px;
    padding: 11px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background: #ffffff;
    color: #111827;
    font: inherit;
    outline: none;
  }

  .form-field input:focus {
    border-color: #e30613;
    box-shadow: 0 0 0 3px rgba(227, 6, 19, 0.1);
  }

  .form-field input[readonly] {
    background: #f8fafc;
    color: #475569;
  }

  .form-field small {
    color: #64748b;
    font-size: 12px;
  }

  .submit-button {
    min-height: 50px;
    border: 0;
    border-radius: 10px;
    background: #e30613;
    color: #ffffff;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .submit-button:hover {
    background: #c9000b;
  }

.submit-button:disabled {
  cursor: wait;
  opacity: 0.7;
}

  .submit-button:focus-visible {
    outline: 3px solid #ffd600;
    outline-offset: 3px;
  }

  .form-message {
    padding: 14px 16px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.5;
  }

  .success-message {
    border: 1px solid #86efac;
    background: #f0fdf4;
    color: #166534;
  }

  .failure-message {
    border: 1px solid #fca5a5;
    background: #fef2f2;
    color: #991b1b;
  }

  @media (max-width: 900px) {
    .quote-page {
      padding-top: 132px;
    }
  }

  @media (max-width: 600px) {
    .quote-section {
      padding: 44px 14px 60px;
    }

    .quote-form {
      padding: 22px 16px;
      border-radius: 14px;
    }
  }
</style>