---
import Header from "../../components/Header.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Conveyor Belt & Systems in Sri Lanka | Vahako</title>
    <meta
      name="description"
      content="Vahako provides conveyor belt and conveyor system solutions in Sri Lanka for factories, warehouses and industrial operations."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <div class="hero-container">
          <div class="hero-image">
            <img
              src="/images/conveyor-belt-sri-lanka.webp"
              alt="Conveyor belt and conveyor systems in Sri Lanka"
              width="800"
              height="800"
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <div class="hero-content">
            <h1>Conveyor Belt &amp; Systems in Sri Lanka</h1>

            <p>
              Vahako provides reliable conveyor belt and conveyor system solutions
              for factories, warehouses, production lines and industrial material
              handling requirements. As a conveyor system manufacturer, we support
              businesses looking for durable conveyor belt Sri Lanka solutions,
              practical system designs and guidance on conveyor belt price in Sri
              Lanka based on size, material, load capacity and project requirement.
            </p>
          </div>
        </div>
      </section>

      <section class="services-overview">
  <div class="services-inner">
    <h2 class="services-title">Our Conveyor Services</h2>

    <div class="services-grid">

      <article class="service-card">
        <h2>Conveyor Belts</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-belt-in-srilanka-from-vahako.webp"
            alt="Industrial conveyor belts supplied by Vahako in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>Quality conveyor belts supplied for reliable industrial material handling.</p>
      </article>

      <article class="service-card">
        <h2>Conveyor Accessories</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-accessories-in-sri-lanka.webp"
            alt="Conveyor motors rollers and belt joining clips in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>Motors, rollers and clips supplied for dependable conveyor operations.</p>
      </article>

      <article class="service-card">
        <h2>Conveyor System Design</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-system-in-sri-lanka.webp"
            alt="Custom conveyor system design and manufacturing services in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>Custom conveyor systems designed for efficient industrial production requirements.</p>
      </article>

      <article class="service-card">
        <h2>Conveyor Repairs</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-system-repair-and-service-in-sri-lanka.webp"
            alt="Industrial conveyor repair and maintenance services in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>Professional conveyor repairs restore reliable performance and reduce production downtime.</p>
      </article>

      <article class="service-card">
        <h2>Conveyor Modifications</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-modification-service.webp"
            alt="Existing conveyor system modification services provided in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>Existing conveyors modified to meet changing industrial production requirements.</p>
      </article>

      <article class="service-card">
        <h2>On-site Belt Vulcanizing</h2>

        <div class="service-image">
          <img
            src="/images/conveyor-belt-vulcanizing-services.webp"
            alt="On-site conveyor belt vulcanizing and joining services in Sri Lanka"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>

        <p>On-site conveyor belt vulcanizing ensures strong durable seamless joints.</p>
      </article>

    </div>
  </div>
</section>

<section class="contact-section" aria-labelledby="contact-title">
  <div class="contact-inner">
    <p class="contact-eyebrow">Discuss your conveyor requirement</p>

    <h2 id="contact-title">Contact Vahako</h2>

    <p class="contact-description">
      Contact our team for conveyor belts, components, system design, repairs,
      modifications and on-site vulcanizing services in Sri Lanka.
    </p>

    <div class="contact-actions">
      <a
        class="contact-button whatsapp-button"
        href="https://wa.me/94707797770?text=I%20am%20interested%20in%20conveyors%20from%20Vahako"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contact Vahako about conveyors through WhatsApp"
      >
        <svg
          viewBox="0 0 24 24"
          width="23"
          height="23"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12.04 2a9.84 9.84 0 0 0-8.53 14.75L2 22l5.38-1.41A9.98 9.98 0 1 0 12.04 2Zm0 17.95a8.03 8.03 0 0 1-4.09-1.12l-.29-.17-3.19.84.85-3.11-.19-.32A8.02 8.02 0 1 1 12.04 19.95Zm4.4-6.01c-.24-.12-1.43-.71-1.65-.79-.22-.08-.38-.12-.54.12-.16.24-.62.79-.76.95-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.93-1.19-.71-.64-1.2-1.43-1.34-1.67-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.19-.47-.39-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.69 2.58 4.1 3.62.57.25 1.02.4 1.37.51.58.18 1.1.16 1.51.1.46-.07 1.43-.58 1.63-1.15.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28Z"/>
        </svg>

        <span>
          <strong>WhatsApp Us</strong>
          <small>070 779 7770</small>
        </span>
      </a>

      <a
        class="contact-button quote-button"
        href="/get-quote?page=Conveyor%20Belt%20and%20Systems"
      >
        <svg
          viewBox="0 0 24 24"
          width="22"
          height="22"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
          <path d="M14 2v6h6" />
          <path d="M8 13h8" />
          <path d="M8 17h6" />
        </svg>

        <span>
          <strong>Get a Quote</strong>
          <small>Submit your requirements</small>
        </span>
      </a>
    </div>
  </div>
</section>

    </main>
  </body>
</html>

<style>

html,
body {
  width: 100%;
  max-width: 100%;
  overflow-x: clip;
}

  body {
    margin: 0;
    font-family: Helvetica, Arial, system-ui, sans-serif;
    background: #ffffff;
    color: #000000;
  }

  .hero {
    padding-top: 120px;
    padding-bottom: 70px;
    background: #ffffff;
  }

  .hero-container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
  box-sizing: border-box;

  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 60px;
  align-items: stretch;
}

.hero-image,
.hero-content,
.services-grid,
.service-card,
.contact-inner,
.contact-actions {
  min-width: 0;
}

  .hero-image {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 18px;
    background: #f3f4f6;
}

  .hero-image img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
    object-fit: cover;
}

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
  }

  .hero-content h1 {
    margin: 0 0 24px;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -1px;
    color: #e30613;
    text-align: left;
  }

  .hero-content p {
    margin: 0;
    max-width: 560px;
    font-size: clamp(17px, 1.5vw, 22px);
    line-height: 1.65;
    font-weight: 500;
    color: #000000;
    text-align: left;
  }

  @media (max-width: 900px) {
    .hero {
      padding-top: 135px;
      padding-bottom: 50px;
    }

    .hero-container {
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: center;
    }

    .hero-content {
      align-items: center;
      text-align: center;
    }

    .hero-content h1,
    .hero-content p {
      text-align: center;
    }
  }

.services-overview {
  padding: 72px 20px;
  border-top: 1px solid #e5e7eb;
  background: #ffffff;
}

.services-inner {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

.services-title {
  margin: 0 0 46px;
  text-align: center;
  color: #e30613;
  font-size: clamp(32px, 4vw, 52px);
  line-height: 1.1;
  font-weight: 900;
  letter-spacing: -1px;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 38px 28px;
}

.service-card {
  min-width: 0;
  text-align: center;
}

.service-card h2 {
  margin: 0 0 16px;
  color: #e30613;
  font-size: clamp(21px, 2vw, 27px);
  line-height: 1.2;
  font-weight: 800;
}

.service-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 16px;
  background: #f3f4f6;
}

.service-image img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.service-card p {
  margin: 16px auto 0;
  max-width: 340px;
  color: #222222;
  font-size: 16px;
  line-height: 1.55;
}

@media (max-width: 900px) {
  .services-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 600px) {
  .services-overview {
    padding: 52px 16px;
  }

  .services-grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }
}


.contact-section {
  padding: 76px 20px;
  border-top: 1px solid #e5e7eb;
  background: #f8fafc;
}

.contact-inner {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  text-align: center;
}

.contact-eyebrow {
  margin: 0 0 10px;
  color: #e30613;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.contact-inner h2 {
  margin: 0 0 16px;
  color: #111111;
  font-size: clamp(34px, 5vw, 54px);
  line-height: 1.05;
  font-weight: 900;
  letter-spacing: -1px;
}

.contact-description {
  max-width: 700px;
  margin: 0 auto 34px;
  color: #475569;
  font-size: 17px;
  line-height: 1.65;
}

.contact-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  max-width: 700px;
  margin: 0 auto;
}

.contact-button {
  min-height: 74px;
  padding: 14px 22px;
  border-radius: 14px;

  display: flex;
  align-items: center;
  justify-content: center;
  gap: 13px;

  text-decoration: none;
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    background-color 0.18s ease;
}

.contact-button:hover {
  transform: translateY(-2px);
}

.contact-button span {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 3px;
  text-align: left;
}

.contact-button strong {
  font-size: 17px;
  line-height: 1.2;
}

.contact-button small {
  font-size: 13px;
  font-weight: 600;
}

.whatsapp-button {
  background: #128c4a;
  color: #ffffff;
  box-shadow: 0 12px 24px rgba(18, 140, 74, 0.18);
}

.whatsapp-button:hover {
  background: #0f7a40;
  box-shadow: 0 16px 30px rgba(18, 140, 74, 0.24);
}

.quote-button {
  border: 2px solid #e30613;
  background: #ffffff;
  color: #e30613;
}

.quote-button:hover {
  background: #e30613;
  color: #ffffff;
  box-shadow: 0 16px 30px rgba(227, 6, 19, 0.16);
}

@media (max-width: 600px) {
  .contact-section {
    padding: 56px 16px;
  }

  .contact-actions {
    grid-template-columns: 1fr;
  }

  .contact-button {
    width: 100%;
  }
}


</style>