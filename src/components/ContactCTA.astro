---
const {
  eyebrow = "Discuss your requirement",
  title = "Contact Vahako",
  description,
  whatsappMessage,
  quotePage,
  phoneDisplay = "0703336339",
  phoneNumber = "94703337770"
} = Astro.props;

const whatsappUrl =
  `https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;

const quoteUrl =
  `/get-quote?page=${encodeURIComponent(quotePage)}`;
---

<section class="contact-section" aria-labelledby="contact-title">
  <div class="contact-inner">
    <p class="contact-eyebrow">{eyebrow}</p>

    <h2 id="contact-title">{title}</h2>

    <p class="contact-description">
      {description}
    </p>

    <div class="contact-actions">
      <a
        class="contact-button whatsapp-button"
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Contact Vahako about ${quotePage} through WhatsApp`}
      >
        <svg
          viewBox="0 0 24 24"
          width="23"
          height="23"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12.04 2a9.84 9.84 0 0 0-8.53 14.75L2 22l5.38-1.41A9.98 9.98 0 1 0 12.04 2Zm0 17.95a8.03 8.03 0 0 1-4.09-1.12l-.29-.17-3.19.84.85-3.11-.19-.32A8.02 8.02 0 1 1 12.04 19.95Zm4.4-6.01c-.24-.12-1.43-.71-1.65-.79-.22-.08-.38-.12-.54.12-.16.24-.62.79-.76.95-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.93-1.19-.71-.64-1.2-1.43-1.34-1.67-.14-.24-.01-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.19-.47-.39-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.69 2.58 4.1 3.62.57.25 1.02.4 1.37.51.58.18 1.1.16 1.51.1.46-.07 1.43-.58 1.63-1.15.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28Z" />
        </svg>

        <span>
          <strong>WhatsApp Us</strong>
          <small>{phoneDisplay}</small>
        </span>
      </a>

      <a
        class="contact-button quote-button"
        href={quoteUrl}
      >
        <svg
          viewBox="0 0 24 24"
          width="22"
          height="22"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
          <path d="M14 2v6h6" />
          <path d="M8 13h8" />
          <path d="M8 17h6" />
        </svg>

        <span>
          <strong>Get a Quote</strong>
          <small>Submit your requirements</small>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    box-sizing: border-box;
    width: 100%;
    padding: 76px 20px;
    border-top: 1px solid #e5e7eb;
    background: #f8fafc;
  }

  .contact-inner {
    width: 100%;
    max-width: 900px;
    min-width: 0;
    margin: 0 auto;
    text-align: center;
  }

  .contact-eyebrow {
    margin: 0 0 10px;
    color: #e30613;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-inner h2 {
    margin: 0 0 16px;
    color: #111111;
    font-size: clamp(34px, 5vw, 54px);
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -1px;
  }

  .contact-description {
    max-width: 700px;
    margin: 0 auto 34px;
    color: #475569;
    font-size: 17px;
    line-height: 1.65;
  }

  .contact-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    width: 100%;
    max-width: 700px;
    min-width: 0;
    margin: 0 auto;
  }

  .contact-button {
    box-sizing: border-box;
    min-height: 74px;
    padding: 14px 22px;
    border-radius: 14px;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;

    text-decoration: none;

    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .contact-button:hover {
    transform: translateY(-2px);
  }

  .contact-button:focus-visible {
    outline: 3px solid rgba(227, 6, 19, 0.3);
    outline-offset: 3px;
  }

  .contact-button span {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
    text-align: left;
  }

  .contact-button strong {
    font-size: 17px;
    line-height: 1.2;
  }

  .contact-button small {
    font-size: 13px;
    font-weight: 600;
  }

  .whatsapp-button {
    background: #128c4a;
    color: #ffffff;
    box-shadow: 0 12px 24px rgba(18, 140, 74, 0.18);
  }

  .whatsapp-button:hover {
    background: #0f7a40;
    box-shadow: 0 16px 30px rgba(18, 140, 74, 0.24);
  }

  .quote-button {
    border: 2px solid #e30613;
    background: #ffffff;
    color: #e30613;
  }

  .quote-button:hover {
    background: #e30613;
    color: #ffffff;
    box-shadow: 0 16px 30px rgba(227, 6, 19, 0.16);
  }

  @media (max-width: 600px) {
    .contact-section {
      padding: 64px 24px;
    }

    .contact-actions {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 100%;
    }

    .contact-button {
      width: 100%;
    }

    .contact-button span {
      align-items: center;
      text-align: center;
    }

    .contact-description {
      max-width: 100%;
      margin-bottom: 36px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-button {
      transition: none;
    }

    .contact-button:hover {
      transform: none;
    }
  }
</style>